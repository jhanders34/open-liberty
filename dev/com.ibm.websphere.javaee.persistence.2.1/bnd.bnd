-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

Bundle-SymbolicName: com.ibm.websphere.javaee.persistence.2.1; singleton:=true

Import-Package: \
  javax.sql; resolution:=optional

Export-Package: javax.persistence.*; jpa=2.1; -split-package:=first

Include-Resource: \
   @${repo;com.ibm.ws.javax.j2ee:persistence;2.1}!/about.html

instrument.disabled: true

publish.wlp.jar.suffix: dev/api/spec

-buildpath: \
	com.ibm.ws.javax.j2ee:persistence;version=2.1
